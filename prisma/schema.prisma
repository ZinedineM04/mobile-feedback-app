generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Feedback {
  id        String   @id @default(cuid())
  pin       String
  category  String   @default("Other")
  text      String?
  imageUrl  String?
  createdAt DateTime @default(now())
}
